# ─── LLM Provider ──────────────────────────────────────────────
# Options: openai | anthropic | google
LLM_PROVIDER=openai

# Model name for the chosen provider
# openai   → gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# anthropic → claude-sonnet-4-20250514
# google   → gemini-2.0-flash, gemini-1.5-pro
LLM_MODEL=gpt-4o

# Provider API keys (only the one matching LLM_PROVIDER is required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...

# ─── Embeddings ────────────────────────────────────────────────
# Embedding model (always OpenAI for consistency in vector space)
EMBEDDING_MODEL=text-embedding-3-small

# ─── ChromaDB ──────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100

# ─── Data paths ────────────────────────────────────────────────
# Path to the annotated CSV (filter sets dump)
FILTER_SETS_CSV=../GSoC-Cohort-Discovery-Chatbot/assets/annotated_amanuensis_search_dump-06-18-2025.csv

# Path to schema files
PROCESSED_GITOPS_JSON=../GSoC-Cohort-Discovery-Chatbot/schema/processed_gitops.json
PROCESSED_SCHEMA_JSON=../GSoC-Cohort-Discovery-Chatbot/schema/processed_pcdc_schema_prod.json
GITOPS_JSON=../GSoC-Cohort-Discovery-Chatbot/schema/gitops.json

# ─── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Guppy (optional — for live query execution) ──────────────
GUPPY_ENDPOINT=https://portal.pedscommons.org/guppy/graphql
